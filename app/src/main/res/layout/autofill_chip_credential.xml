<?xml version="1.0" encoding="utf-8"?>
<!--
    Two-line chip showing a real credential match.

    Same RemoteViews constraints as autofill_chip_locked.xml — theme attrs
    don't resolve in the system Autofill UI's process, so every colour goes
    through an explicit @color with a values-night override.

    Visual: 32dp rounded-square brand container on the left (matches the
    locked chip for instant brand recognition), title in bold, username
    quieter below. Both single-line + ellipsised so any combination of
    credential length and screen width yields a tidy row.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_autofill_chip_icon">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_autofill_chip_key"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/autofill_chip_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/autofill_chip_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/autofill_chip_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/autofill_chip_subtitle"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
