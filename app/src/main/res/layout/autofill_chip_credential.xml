<?xml version="1.0" encoding="utf-8"?>
<!--
    Two-line chip showing a real credential match.

    Same constraints as autofill_chip_locked.xml — RemoteViews host process
    can't resolve theme attrs.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/autofill_chip_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#0F1419"
        android:textSize="14sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1" />

    <TextView
        android:id="@+id/autofill_chip_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#5B6470"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1" />
</LinearLayout>
