<?xml version="1.0" encoding="utf-8"?>
<!--
    Single-line chip for the locked-vault and search affordances rendered
    inside the system Autofill dropdown.

    Layout constraints:
      - Renders in the system Autofill UI's process via RemoteViews. Theme
        attrs do NOT resolve there; every colour is an explicit @color (with
        a values-night override for dark dropdowns).
      - Vector drawables are safe at our minSdk (26 ≥ 24).
      - Only a small subset of View types is supported by RemoteViews:
        LinearLayout / FrameLayout / TextView / ImageView are all fine.

    Visual: 32dp rounded-square brand container on the left (1Key blue) with
    a centred white key glyph; bold blue label on the right. Single line so
    long captions get ellipsised rather than wrapping over two rows (which
    would inflate the dropdown height).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_autofill_chip_icon">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_autofill_chip_key"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <TextView
        android:id="@+id/autofill_chip_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/autofill_chip_accent"
        android:textSize="15sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1" />
</LinearLayout>
